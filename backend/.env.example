# ============================================
# NEXUS Platform - Configuration Backend
# Version: 3.12.0
# Derniere MAJ: 2026-03-07
# ============================================
#
# Variables REQUISES sur Render (25 vars) :
# ADMIN_PASSWORD, ANTHROPIC_API_KEY, CORS_ORIGIN, JWT_SECRET,
# NODE_ENV, OPENAI_API_KEY, PORT, REDIS_URL, REPLICATE_API_TOKEN,
# RESEND_API_KEY, SENTRY_DSN, STRIPE_PUBLIC_KEY, STRIPE_SECRET_KEY,
# SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_URL,
# TAVILY_API_KEY, TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN,
# TWILIO_FR_ADDRESS_SID, TWILIO_FR_BUNDLE_SID,
# TWILIO_FR_MOBILE_BUNDLE_SID, TWILIO_MESSAGING_SERVICE_SID,
# TWILIO_WABA_BU_SID, WEBHOOK_BASE_URL
# ============================================

# ============================================
# Serveur
# ============================================
PORT=5000
NODE_ENV=development
ADMIN_PASSWORD=your-admin-password

# ============================================
# Supabase (Base de donnees)
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ============================================
# JWT (Authentification)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ============================================
# Stripe (Paiements)
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...

# ============================================
# Twilio (WhatsApp, Voice, SMS)
# ============================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_FR_BUNDLE_SID=BU...
TWILIO_FR_ADDRESS_SID=AD...
TWILIO_FR_MOBILE_BUNDLE_SID=BU...
TWILIO_WABA_BU_SID=BU...

# ============================================
# Anthropic (Claude IA)
# ============================================
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# OpenAI (TTS + DALL-E fallback)
# ============================================
OPENAI_API_KEY=sk-...

# ============================================
# Replicate (Image generation - Flux)
# ============================================
REPLICATE_API_TOKEN=r8_...

# ============================================
# Tavily (Recherche web IA)
# ============================================
TAVILY_API_KEY=tvly-...

# ============================================
# Resend (Emails transactionnels)
# ============================================
RESEND_API_KEY=re_...

# ============================================
# Redis (Queue & Cache)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Sentry (Error Monitoring)
# ============================================
SENTRY_DSN=https://...@sentry.io/...

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3001,http://localhost:5173,http://localhost:5174

# ============================================
# URLs
# ============================================
WEBHOOK_BASE_URL=https://nexus-backend-dev.onrender.com
